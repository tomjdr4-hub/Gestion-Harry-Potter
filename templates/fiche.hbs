<div class="hp4-fiche-wrapper">
  {{#if actor}}
    <div class="hp4-fiche-header">
      <img class="hp4-fiche-portrait"
           src="{{actor.img}}"
           alt="{{actor.name}}"
           title="Voir le portrait complet" />
      <div class="hp4-fiche-name">{{actor.name}}</div>
    </div>

    <div class="hp4-fiche-relations">
      {{#each relations}}
        <div class="hp4-rel-row" style="--rc: {{color}}">
          <div class="hp4-rel-label">{{label}}</div>
          <div class="hp4-rel-drop" data-rel="{{key}}">
            {{#each actors}}
              <div class="hp4-rel-actor" title="{{name}}">
                <img src="{{img}}" alt="{{name}}" />
                <button type="button" class="hp4-rel-remove"
                        data-actor-id="{{id}}"
                        data-rel="{{../key}}"
                        title="Retirer">
                  <i class="fas fa-times"></i>
                </button>
              </div>
            {{else}}
              <span class="hp4-rel-hint">Glissez un acteur ici</span>
            {{/each}}
          </div>
        </div>
      {{/each}}
    </div>

    <div class="hp4-fiche-section hp4-fiche-section--grow">
      <div class="hp4-fiche-label">Notes</div>
      <textarea class="hp4-fiche-notes"
                placeholder="Notes sur ce personnage…">{{notes}}</textarea>
    </div>
  {{else}}
    <p class="hp4-empty">Acteur introuvable.</p>
  {{/if}}
</div>
